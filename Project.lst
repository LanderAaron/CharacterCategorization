				;----------------------------------------------------------------------------------------------------------------- GetInput Procedure
				; Description: The GetInput procedure prompts the user for input and reads a string into the buffer. It also 
				; returns the length of the string in EAX for later use in iteration.
				; Received: None
				; Returns: EAX = length of the input string
				; Requires: None

 000000BD			GetInput PROC
 000000BD  BA 00000000 R		mov edx, OFFSET prompt
 000000C2  E8 00000000 E		call WriteString
 000000C7  BA 0000001F R		mov edx, OFFSET buffer
 000000CC  B9 0000007F			mov ecx, MAX - 1
 000000D1  E8 00000000 E		call ReadString

					; Testing Del key because ReadString does not capture it
					; mov BYTE PTR [buffer], 127

 000000D6  C3				ret
 000000D7			GetInput ENDP
				;----------------------------------------------------------------------------------------------------------------- LoopThrough Procedure
				; Description: LoopThrough procedure takes the length of the string in ECX and iterates through each character in 
				; the buffer. It classifies each character, displays its ASCII value, and updates category totals.
				; Received: ECX = length of the input string
				; Returns: None
				; Requires: EAX = current character, ESI = pointer to current character in buffer

 000000D7			LoopThrough PROC USES eax ecx edx esi
 000000D7  50		   *	    push   eax
 000000D8  51		   *	    push   ecx
 000000D9  52		   *	    push   edx
 000000DA  56		   *	    push   esi
 000000DB  83 F9 00			cmp ecx, 0					; If the length of the string is zero, skip the loop
 000000DE  74 67			je EndLoop
 000000E0  BE 0000001F R		mov esi, OFFSET buffer		; Load the address of the buffer into ESI for iteration

 000000E5			NextChar:
 000000E5  B8 00000000			mov eax, 0					; Clear EAX to use for character classification
 000000EA  8A 06			mov al, BYTE PTR [esi]		; Load the current character into AL

					; Handle special characters (space, tab, DEL) with specific labels
 000000EC  3C 20			cmp al, 32					; Check if the character is a space (ASCII 32)
 000000EE  74 0F			je PrintSpaceLabel

 000000F0  3C 09			cmp al, 9					; Check if the character is a tab (ASCII 9)
 000000F2  74 17			je PrintTabLabel

 000000F4  3C 7F			cmp al, 127					; Check if the character is a DEL (ASCII 127)
 000000F6  74 1F			je PrintDelLabel

					; For all other characters, proceed with normal classification and display
 000000F8  E8 00000000 E		call WriteChar
 000000FD  EB 22			jmp ContinueLoop

				; Print labels for special characters
 000000FF			PrintSpaceLabel:
 000000FF  BA 00000171 R		mov edx, OFFSET spaceLabel
 00000104  E8 00000000 E		call WriteString
 00000109  EB 16			jmp ContinueLoop

 0000010B			PrintTabLabel:
 0000010B  BA 00000179 R		mov edx, OFFSET tabLabel
 00000110  E8 00000000 E		call WriteString
 00000115  EB 0A			jmp ContinueLoop

 00000117			PrintDelLabel:
 00000117  BA 0000017F R		mov edx, OFFSET delLabel
 0000011C  E8 00000000 E		call WriteString

				; Continues loop for normal characters
 00000121			ContinueLoop:
 00000121  BA 000000A0 R		mov edx, OFFSET separator	; Display the separator
 00000126  E8 00000000 E		call WriteString
 0000012B  E8 00000000 E		call WriteDec				; Display the ASCII value of the character
 00000130  BA 000000A4 R		mov edx, OFFSET separator2	; Display the second separator
 00000135  E8 00000000 E		call WriteString
 0000013A  E8 0000000D			call Categorize				; Call the Categorize procedure to classify the character and update totals
 0000013F  E8 00000000 E		call Crlf					
 00000144  46				inc esi						; Move to the next character
 00000145  E2 9E			loop NextChar				; Loop until ECX is zero
 00000147			EndLoop:
					ret
 00000147  5E		   *	    pop    esi
 00000148  5A		   *	    pop    edx
 00000149  59		   *	    pop    ecx
 0000014A  58		   *	    pop    eax
 0000014B  C3		   *	    ret    00000h
 0000014C			LoopThrough ENDP
				;----------------------------------------------------------------------------------------------------------------- Categorize Procedure
				; Description: The Categorize procedure takes the current character in AL, classifies it based on its ASCII value, 
				; updates the appropriate category total, and displays the category name.
				; Received: AL = current character
				; Returns: None
				; Requires: EDX = pointer to category string for display

 0000014C			Categorize PROC USES edx
 0000014C  52		   *	    push   edx
 0000014D  3C 1F			cmp al, 31				; Check if the character is a control character (ASCII 0-31)
 0000014F  76 22			jbe isControlChar

 00000151  3C 2F			cmp al, 47				; Check if the character is a punctuation (ASCII 32-47)
 00000153  76 52			jbe isPuncChar

 00000155  3C 39			cmp al, 57				; Check if the character is a digit (ASCII 48-57)
 00000157  76 27			jbe isDigChar

 00000159  3C 40			cmp al, 64				; Check if the character is a punctuation (ASCII 58-64)
 0000015B  76 4A			jbe isPuncChar

 0000015D  3C 5A			cmp al, 90				; Check if the character is an uppercase letter (ASCII 65-90)
 0000015F  76 53			jbe isUpChar

 00000161  3C 60			cmp al, 96				; Check if the character is a punctuation (ASCII 91-96)
 00000163  76 42			jbe isPuncChar

 00000165  3C 7A			cmp al, 122				; Check if the character is a lowercase letter (ASCII 97-122)
 00000167  76 31			jbe isLowChar

 00000169  3C 7E			cmp al, 126				; Check if the character is a punctuation (ASCII 123-126)
 0000016B  76 3A			jbe isPuncChar

 0000016D  3C 7F			cmp al, 127				; Check if the character is a DEL character (ASCII 127)
 0000016F  74 1C			je isDelChar

 00000171  EB 53			jmp EndCategorize		; If the character does not fit any category, skip to the end

				; Category Labels
				; Each label moves the appropriate category string into EDX and jumps to PrintCategory to display it

 00000173			isControlChar:
 00000173  FF 05 0000011A R		inc ctrlCount						; Increment control character count
 00000179  BA 000000E2 R		mov edx, OFFSET controlChar			; Move the control character category string into EDX for display
 0000017E  EB 41			jmp PrintCategory					; Jump to PrintCategory to display the category name

 00000180			isDigChar:								
 00000180  FF 05 0000011E R		inc digCount						
 00000186  BA 000000EB R		mov edx, OFFSET digChar
 0000018B  EB 34			jmp PrintCategory

 0000018D			isDelChar:
 0000018D  FF 05 00000122 R		inc delCount
 00000193  BA 000000F2 R		mov edx, OFFSET delChar
 00000198  EB 27			jmp PrintCategory

 0000019A			isLowChar:
 0000019A  FF 05 00000126 R		inc lowCount
 000001A0  BA 000000F7 R		mov edx, OFFSET lowChar
 000001A5  EB 1A			jmp PrintCategory

 000001A7			isPuncChar:
 000001A7  FF 05 0000012A R		inc puncCount
 000001AD  BA 00000102 R		mov edx, OFFSET puncChar
 000001B2  EB 0D			jmp PrintCategory

 000001B4			isUpChar:
 000001B4  FF 05 0000012E R		inc upCount
 000001BA  BA 0000010F R		mov edx, OFFSET upChar
 000001BF  EB 00			jmp PrintCategory

 000001C1			PrintCategory:
 000001C1  E8 00000000 E		call WriteString			

 000001C6			EndCategorize:
					ret
 000001C6  5A		   *	    pop    edx
 000001C7  C3		   *	    ret    00000h
 000001C8			Categorize ENDP
				;-----------------------------------------------------------------------------------------------------------------
				END main

