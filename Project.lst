 00000000			.code
				;----------------------------------------------------------------------------------------------------------------- Main Procedure
				; Main = control program flow

 00000000			main PROC
 00000000  E8 000000B8			call GetInput

					; Move the length of the string into ECX for iteration
 00000005  8B C8			mov ecx, eax				
 00000007  E8 000000CB			call LoopThrough

					; Display totals for each category
 0000000C  E8 00000000 E		call Crlf
 00000011  BA 000000C0 R		mov edx, OFFSET totalsTitle
 00000016  E8 00000000 E		call WriteString
 0000001B  E8 00000000 E		call Crlf

 00000020  BA 00000132 R		mov edx, OFFSET msgControl	
 00000025  E8 00000000 E		call WriteString
 0000002A  A1 0000011A R		mov eax, ctrlCount
 0000002F  E8 00000000 E		call WriteDec
 00000034  E8 00000000 E		call Crlf

 00000039  BA 0000013C R		mov edx, OFFSET msgDigit
 0000003E  E8 00000000 E		call WriteString
 00000043  A1 0000011E R		mov eax, digCount
 00000048  E8 00000000 E		call WriteDec
 0000004D  E8 00000000 E		call Crlf

 00000052  BA 00000145 R		mov edx, OFFSET msgDel
 00000057  E8 00000000 E		call WriteString
