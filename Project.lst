 0000008E  A1 0000012A R		mov eax, puncCount
 00000093  E8 00000000 E		call WriteDec
 00000098  E8 00000000 E		call Crlf

 0000009D  BA 00000165 R		mov edx, OFFSET msgUpper
 000000A2  E8 00000000 E		call WriteString
 000000A7  A1 0000012E R		mov eax, upCount
 000000AC  E8 00000000 E		call WriteDec
